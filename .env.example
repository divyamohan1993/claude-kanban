PORT=51777
PROJECTS_ROOT=R:\

# Max simultaneous Claude build sessions (default: 1)
MAX_CONCURRENT_BUILDS=1

# Build timeout in minutes (default: 60)
BUILD_TIMEOUT_MINS=60

# Daily backup retention in days (default: 7). Hot and hourly managed automatically.
# BACKUP_RETENTION_DAYS=7

# Idle timeout in minutes — no log activity = stalled (default: 15)
# IDLE_TIMEOUT_MINS=15

# Auto-pause pipeline when Claude Max usage exceeds this % (default: 80)
# Checks both 5-hour session and 7-day weekly limits from claude.ai
# USAGE_PAUSE_PCT=80

# Self-imposed session limits (0 = unlimited). Board-level tracking, independent of plan limits.
# MAX_HOURLY_SESSIONS=0
# MAX_WEEKLY_SESSIONS=0

# Optional: webhook URL for card state change notifications
# WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Admin server port (default: PORT + 1). Bound to 127.0.0.1 — unreachable from external IPs.
# ADMIN_PORT=51778

# Admin PIN for Control Panel access (leave empty for no-auth localhost mode)
# When set, all admin write APIs require this PIN even on localhost.
# ADMIN_PIN=

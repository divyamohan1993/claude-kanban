PORT=51777
# PROJECTS_ROOT=~/Projects

# Authentication credentials (REQUIRED for production).
# If not set, defaults to admin/admin and user/user with a loud warning.
ADMIN_PASSWORD=change-me-admin
USER_PASSWORD=change-me-user

# Path-based routing (set by autoconfig.sh for Nginx deployments).
# Leave empty for local dev (serves at root /).
# BASE_PATH=/dashboard
# SETTINGS_BASE_PATH=/settings
# ADMIN_PORT=51778

# Everything else has sensible defaults and is runtime-editable
# from the control panel. See docs/configuration.md for the full
# list of 70+ environment variables.

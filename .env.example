PORT=51777
# PROJECTS_ROOT=~/Projects

# --- Secret Vault (recommended for production) ---
# Cloudflare Worker vault with 10-layer defense in depth.
# Secrets fetched at startup, held in memory only, never on disk.
# Master key is split: half in Worker, half here. HKDF derives the real key.
# Neither half alone is useful. See deploy/secret-vault-worker/ for setup.
#
# SECRET_BROKER_URL=https://your-random-name.your-account.workers.dev/secrets
# SECRET_BROKER_CLIENT_ID=<client-id: from vault /setup UI>
# SECRET_BROKER_HMAC_KEY=<key-A: for HMAC request signing>
# SECRET_BROKER_ENC_KEY=<key-B: 32-byte hex, for AES-256-GCM request/response encryption>
# SECRET_BROKER_DERIVE_KEY=<half-B: 32-byte hex, for HKDF key derivation with vault's half-A>

# Authentication credentials (REQUIRED for production).
# If not set, defaults to admin/admin and user/user with a loud warning.
ADMIN_PASSWORD=change-me-admin
USER_PASSWORD=change-me-user

# --- Claude ---
# CLAUDE_MODEL=claude-opus-4-6
# CLAUDE_EFFORT=high

# --- Pipeline ---
# Max simultaneous Claude build sessions (default: 1)
MAX_CONCURRENT_BUILDS=1

# Build timeout in minutes (default: 60)
BUILD_TIMEOUT_MINS=60

# Idle timeout in minutes, no log activity = stalled (default: 15)
IDLE_TIMEOUT_MINS=15

# Daily backup retention in days (default: 7). Hot and hourly managed automatically.
BACKUP_RETENTION_DAYS=7

# --- Usage Limits ---
# Auto-pause pipeline when Claude Max usage exceeds this % (default: 80)
# Checks both 5-hour session and 7-day weekly limits from claude.ai
USAGE_PAUSE_PCT=80

# Self-imposed session limits (0 = unlimited). Board-level tracking, independent of plan limits.
MAX_HOURLY_SESSIONS=0
MAX_WEEKLY_SESSIONS=0

# Optional: webhook URL for card state change notifications
# WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# --- Server ---
# Admin server port, auto-generated random ephemeral port each start.
# Set to pin a specific port (e.g. for nginx proxy). Omit to randomize.
# ADMIN_PORT=51778

# Admin panel URL path, auto-generated 52-char random hex each start.
# Set to pin a specific path. Omit to randomize. Super admin sees URL in console on start.
# ADMIN_PATH=admin

# Force HSTS header even without X-Forwarded-Proto. Set true when behind HTTPS proxy.
# ENABLE_HSTS=true

# --- Mode: Single-Project Autonomous CI/CD ---
# Operating mode: 'global' (multi-project, default) or 'single-project' (autonomous)
KANBAN_MODE=global

# Project folder for single-project mode (default: parent of kanban install dir)
SINGLE_PROJECT_PATH=

# Auto-promote brainstorm ideas to todo tasks (default: true)
# false = brainstorm completes but waits for human approval before decomposing
AUTO_PROMOTE_BRAINSTORM=true

# Max brainstorm ideas queued at once (default: 3)
MAX_BRAINSTORM_QUEUE=1

# Discovery scan interval in minutes (default: 30, 0 = disabled)
DISCOVERY_INTERVAL_MINS=30

# Max child/todo cards per brainstorm initiative (default: 10)
MAX_CHILD_CARDS=10

# --- Spec Intelligence ---
# Multi-lens brainstorm: forces multi-perspective analysis (default: true)
# MULTI_LENS_BRAINSTORM=true

# Percentage of brainstorms that receive creative thinking constraints (default: 20)
# CREATIVE_CONSTRAINT_PCT=20

# Score spec effectiveness and learn patterns over time (default: true)
# SPEC_FEEDBACK_LOOP=true

# Percentage of brainstorms that receive confrontational challenges (default: 70)
# CONFRONTATIONAL_PCT=70

# If true, brainstorm outputs go to spec-ready status for human approval (default: false)
# SPEC_APPROVAL_GATE=false

# --- Rate Limiting ---
# Token bucket: general API (default: 200 burst, 100/s refill)
# RATE_LIMIT_GENERAL_BURST=200
# RATE_LIMIT_GENERAL_REFILL=100

# Token bucket: auth endpoints (default: 5 burst, 1/s refill)
# RATE_LIMIT_AUTH_BURST=5
# RATE_LIMIT_AUTH_REFILL=1

# SSE connection limits (default: 5 per IP, 200 global)
# SSE_MAX_PER_IP=5
# SSE_MAX_TOTAL=200

# --- Data Retention ---
# LOG_RETENTION_DAYS=7
# SNAPSHOT_ARCHIVE_RETENTION_DAYS=14
# MAX_AUDIT_ROWS=10000
# MAX_ARCHIVED=50

# --- Polling & Timeouts ---
# POLL_INTERVAL_MS=5000
# BRAINSTORM_TIMEOUT_MINS=30
# DECOMPOSE_TIMEOUT_MINS=15
# SELF_HEAL_TIMEOUT_MINS=10
# LOG_SCAN_INTERVAL_SECS=30
# HOUSEKEEPING_INTERVAL_MINS=60

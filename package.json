{
  "name": "claude-kanban",
  "version": "3.3.0",
  "description": "AI-powered Kanban board that orchestrates autonomous Claude Code sessions — zero-touch build-review-ship pipeline",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node tests/run-all.js",
    "test:reliability": "node tests/march-of-nines.js",
    "test:security": "node tests/dependency-audit.js",
    "test:perf": "node tests/performance-benchmark.js",
    "test:durability": "node tests/data-durability.js",
    "test:quality": "node tests/code-quality.js"
  },
  "keywords": [
    "claude",
    "kanban",
    "ai",
    "automation",
    "code-review",
    "ci-cd",
    "claude-code",
    "anthropic",
    "autonomous",
    "orchestrator"
  ],
  "author": "Divya Mohan (https://dmj.one)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/divyamohan1993/claude-kanban.git"
  },
  "homepage": "https://github.com/divyamohan1993/claude-kanban#readme",
  "bugs": {
    "url": "https://github.com/divyamohan1993/claude-kanban/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "argon2"
    ]
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "better-sqlite3": "^11.7.0",
    "express": "^4.21.2",
    "pino": "^10.3.1"
  }
}
